# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA
POSTGRES_DB=samba_db

# ─── JWT (mesmo secret em todos os projetos) ──────────────────────────────────
JWT_SECRET=TROQUE_POR_STRING_LONGA_E_ALEATORIA
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# ─── Connection strings por app ───────────────────────────────────────────────
# samba-access (admin, acesso total)
DATABASE_URL_ACCESS=postgresql://postgres:TROQUE_ESTA_SENHA@localhost:5433/samba_db

# samba-code (schema samba_school read + samba_code full)
DATABASE_URL_CODE=postgresql://samba_code_user:TROQUE_ESTA_SENHA@localhost:5433/samba_db

# samba-edvance (schema samba_school read + samba_edvance full)
DATABASE_URL_EDVANCE=postgresql://samba_edvance_user:TROQUE_ESTA_SENHA@localhost:5433/samba_db
